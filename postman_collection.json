{
  "info": {
    "name": "DeskFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Login Issue\",\n  \"description\": \"I cannot log into my account.\",\n  \"customerEmail\": \"customer@example.com\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets"
              ]
            }
          }
        },
        {
          "name": "Get Tickets (Filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tickets?status=open&priority=high&breached=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "open"
                },
                {
                  "key": "priority",
                  "value": "high"
                },
                {
                  "key": "breached",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Update Ticket Status (Valid)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "TICKET_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Update Ticket Status (Invalid Transition)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "TICKET_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Get Ticket Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tickets/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets",
                "stats"
              ]
            }
          }
        },
        {
          "name": "Delete Ticket",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tickets/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tickets",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "TICKET_ID_HERE"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}
